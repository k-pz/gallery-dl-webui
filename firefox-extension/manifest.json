{
  "manifest_version": 3,
  "name": "gallery-dl-webui — Add to library",
  "short_name": "gallery-dl-webui",
  "version": "0.1.0",
  "description": "Add the current manga page to your gallery-dl-webui library in one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gallery-dl-webui@piekarczyk.org",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Add to manga library",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
