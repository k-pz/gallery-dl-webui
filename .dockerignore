# Keep the build context small + reproducible. Anything below is *not* sent
# to the Docker daemon, which speeds up COPY and avoids leaking local state
# (venvs, caches, data dirs) into the image.

# Per-side build artefacts
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.pytest_cache/
backend/.ruff_cache/
backend/.ty_cache/
backend/tests/
frontend/node_modules/
frontend/dist/
frontend/test-results/
frontend/playwright-report/

# Local dev state
data/
data-e2e/
media/

# Editor / VCS / OS noise
.git/
.gitignore
.github/
.idea/
.vscode/
.DS_Store

# Repo-level dev tooling we don't need at runtime
.claude/
.local/
.ruff_cache/
mise.toml
scripts/
wiki/
docker-compose.yml
README.md
ARCHITECTURE.md
